  "conformance_levels": [
    {
      "level": 1,
      "name": "Verify",
      "description": "Can verify an existing receipt's content_hash and receipt_id against the canonical JSON encoding algorithm.",
      "required_artifacts": [
        "schemas/test_vectors.json"
      ]
    },
    {
      "level": 2,
      "name": "Generate",
      "description": "Level 1 + can produce valid receipts with correct canonical JSON encoding. Must pass JSON Schema validation.",
      "required_artifacts": [
        "schemas/test_vectors.json",
        "schemas/commit_receipt.v1.schema.json"
      ]
    },
    {
      "level": 3,
      "name": "Full",
      "description": "Level 2 + CBOR round-trip: JSON → CBOR → JSON produces identical content_hash and receipt_id values.",
      "required_artifacts": [
        "schemas/test_vectors.json",
        "schemas/cbor_test_vectors.json",
        "schemas/commit_receipt.v1.schema.json"
      ]
    }
  ],
