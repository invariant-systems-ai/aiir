{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invariantsystems.io/schemas/aiir/decision_receipt.v1.schema.json",
  "title": "AIIR Decision Receipt v1",
  "description": "Content-addressed receipt for a single policy gate evaluation. Finer grain than commit receipts: one decision receipt per policy-rule evaluation, per commit, per gate invocation. Schema: aiir/decision_receipt.v1",
  "type": "object",
  "required": [
    "type",
    "schema",
    "version",
    "decision",
    "subject",
    "policy",
    "provenance",
    "receipt_id",
    "content_hash",
    "timestamp",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "aiir.decision_receipt",
      "description": "Receipt type identifier. MUST be 'aiir.decision_receipt'."
    },
    "schema": {
      "const": "aiir/decision_receipt.v1",
      "description": "Schema version identifier."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([.+\\-][0-9a-zA-Z.+\\-]*)?$",
      "description": "SemVer version of the tool that generated this receipt."
    },
    "decision": {
      "type": "object",
      "required": ["rule_id", "result", "evaluator"],
      "additionalProperties": false,
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^EPB-[0-9]{3}$",
          "description": "The profile rule that was evaluated (e.g., 'EPB-009')."
        },
        "result": {
          "type": "string",
          "enum": ["PASS", "FAIL", "SKIP"],
          "description": "The outcome of this rule evaluation."
        },
        "evaluator": {
          "type": "string",
          "description": "Identifier of the evaluator (e.g., 'aiir.cli', 'opa', 'kyverno')."
        },
        "reason": {
          "type": "string",
          "maxLength": 2000,
          "description": "Human-readable explanation of the decision."
        },
        "evidence": {
          "type": "object",
          "description": "Key-value pairs of the exact field values that were inputs to this rule evaluation.",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "required": ["commit_sha"],
      "additionalProperties": false,
      "properties": {
        "commit_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
          "description": "The commit SHA this decision applies to."
        },
        "receipt_id": {
          "type": "string",
          "pattern": "^g1-[0-9a-f]{32}$",
          "description": "Optional receipt_id of the commit receipt that was evaluated."
        },
        "review_receipt_id": {
          "type": "string",
          "pattern": "^g1-[0-9a-f]{32}$",
          "description": "Optional receipt_id of the review receipt that was evaluated."
        }
      }
    },
    "policy": {
      "type": "object",
      "required": ["profile", "digest"],
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string",
          "description": "URI or name of the profile that was evaluated (e.g., 'aiir/enterprise_protected_branch.v1')."
        },
        "digest": {
          "type": "object",
          "required": ["sha256"],
          "additionalProperties": false,
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$",
              "description": "SHA-256 digest of the canonical JSON profile configuration."
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["tool", "generator"],
      "properties": {
        "repository": {
          "type": ["string", "null"],
          "description": "Repository URL."
        },
        "tool": {
          "type": "string",
          "description": "URI-based tool identifier."
        },
        "generator": {
          "type": "string",
          "description": "Generator identifier."
        }
      },
      "additionalProperties": false
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^g1-[0-9a-f]{32}$",
      "description": "Truncated content hash serving as unique receipt identifier."
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "SHA-256 of the canonical JSON encoding of the core fields."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp of receipt generation."
    },
    "extensions": {
      "type": "object",
      "description": "Annotation-only metadata. NOT part of the content hash.",
      "properties": {
        "instance_id": {
          "type": "string",
          "maxLength": 200
        },
        "namespace": {
          "type": "string",
          "maxLength": 200
        }
      },
      "additionalProperties": true
    }
  }
}
